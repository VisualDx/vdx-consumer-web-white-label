# VisualDx API credentials
# Get these from VisualDx API dashboard
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# Audience setting: "consumer" or "clinical"
AUDIENCE=clinical

# Upstream API base URL
API_BASE_URL=https://api-dev.visualdx.com/v1

# Token endpoint
TOKEN_URL=https://api-dev.visualdx.com/v1/auth/token

# Cache TTL in seconds (72 hours)
CACHE_TTL=259200

# App URL for origin validation
# Development: http://localhost:3000
# Production: https://your-app.vercel.app or https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Image security secret
# Generate a random secret key for production
# Example: openssl rand -base64 32
IMAGE_SECRET=change-this-to-random-secret-in-production

# App Security Key
# Prevents unauthorized clients from calling your Next.js API routes
# Generate a random string: openssl rand -base64 32
NEXT_PUBLIC_APP_KEY=change-this-to-random-app-key-in-production
